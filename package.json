{
  "name": "ark-admin-nest",
  "version": "1.0.0",
  "description": "A simple and efficient permission management system",
  "author": "hackycy",
  "private": true,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "pnpm prebuild && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "cross-env NODE_ENV=development STARTCONFIG=bootstrap-dev TZ=Asia/Shanghai nest start --watch",
    "dev:hmr": "cross-env NODE_ENV=development STARTCONFIG=bootstrap-dev nest build --webpack --webpackPath webpack-hmr.config.js --watch",
    "dev:debug": "cross-env NODE_ENV=development STARTCONFIG=bootstrap-dev nest start --debug --watch",
    "start": "NODE_ENV=production node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@bull-board/api": "^6.9.2",
    "@fastify/static": "^6.12.0",
    "@liaoliaots/nestjs-redis": "^9.0.5",
    "@nestjs/axios": "^0.1.1",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^9.4.3",
    "@nestjs/config": "^2.3.4",
    "@nestjs/core": "^9.4.3",
    "@nestjs/jwt": "^9.0.0",
    "@nestjs/platform-fastify": "^9.4.3",
    "@nestjs/schedule": "^5.0.1",
    "@nestjs/swagger": "^6.3.0",
    "@nestjs/typeorm": "^9.0.1",
    "bullmq": "^5.43.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "crypto-js": "^4.2.0",
    "dayjs": "^1.11.13",
    "decimal.js": "^10.5.0",
    "fast-json-stringify": "^6.0.1",
    "g": "^2.0.1",
    "ioredis": "^5.5.0",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "mysql2": "^2.3.3",
    "nanoid": "^3.3.8",
    "pnpm": "^10.26.2",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.2",
    "svg-captcha": "^1.4.0",
    "typeorm": "^0.3.21",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.5.0",
    "@nestjs/schematics": "^9.2.0",
    "@nestjs/testing": "^9.4.3",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "28.1.8",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.16",
    "@types/node": "^16.18.126",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^4.2.1",
    "fastify": "^5.2.1",
    "jest": "28.1.3",
    "prettier": "^2.8.8",
    "rimraf": "^3.0.2",
    "run-script-webpack-plugin": "^0.2.3",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.4",
    "ts-jest": "28.0.8",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.1.0",
    "typescript": "^5.8.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
